{
  "name": "quick-actions",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "dev:ui": "concurrently \"vite\" \"pnpm dev:plugins\"",
    "build:ui": "tsc && vite build && pnpm build:plugins",
    "dev:plugins": "pnpm --filter \"./plugins/*\" build --watch",
    "build:plugins": "pnpm --filter \"./plugins/*\" build",
    "tauri": "tauri",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "preview": "vite preview"
  },
  "dependencies": {
    "@heroui/react": "^2.8.10",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "framer-motion": "^11.15.0",
    "lucide-react": "^1.7.0",
    "next-themes": "^0.4.6",
    "pinyin-pro": "^3.28.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.0",
    "postcss": "^8.5.8",
    "postcss-import": "^16.1.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.4"
  }
}
