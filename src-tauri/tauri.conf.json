{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "quick-actions",
  "version": "0.1.0",
  "identifier": "com.develop.quick-actions",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Quick Actions",
        "width": 600,
        "height": 400,
        "center": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": true,
        "url": "index.html"
      },
      {
        "label": "plugin",
        "title": "Plugin UI",
        "width": 1200,
        "height": 800,
        "center": true,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false,
        "focus": true,
        "url": "index.html?window=plugin"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../plugins": "plugins"
    }
  }
}
